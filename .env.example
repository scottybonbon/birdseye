# Birdseye website — environment variable reference.
#
# Copy this file to `.env.local` for local development. Never commit
# `.env.local` (it's gitignored). For production / staging Vercel
# deployments, set these in the Vercel project settings → Environment
# Variables panel — never in the repo.

# ─── WordPress REST API ────────────────────────────────────────────
# The site reads content from the live birdseyesecurity.com WordPress
# install. Override this if pointing the new site at a staging WP
# instance for content rehearsal.
NEXT_PUBLIC_WP_API_URL=https://birdseyesecurity.com/wp-json/wp/v2

# ─── Staging banner + noindex ──────────────────────────────────────
# Set to "true" on the staging deployment in Vercel. When set:
#   • A "Internal preview" filing-line bar renders at the top of every
#     page (StagingBanner component, mounted in app/layout.tsx).
#   • robots.txt returns Disallow: / so search engines skip the URL.
#   • <meta name="robots" content="noindex,nofollow"> is also emitted
#     as a second guard.
# Leave UNSET (or "false") on production.
NEXT_PUBLIC_STAGING=false
